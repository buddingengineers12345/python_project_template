# Environment variables for the Copier template development environment.
# Copy this file to .env and fill in the values for your environment.
# See `just load-env` to automatically copy this file to .env.
#
# This file is committed to version control so contributors can see what
# environment variables are required.

# ===========================================================================
# Development & Testing
# ===========================================================================

# Python version to test against (default: 3.11)
# PYTHON_VERSION=3.11

# Enable verbose output for template rendering and tests
# VERBOSE=false

# Skip certain tests during development
# SKIP_SLOW_TESTS=false

# ===========================================================================
# Template Testing
# ===========================================================================

# Directory for temporary test project generation
# TEST_OUTPUT_DIR=/tmp/copier-test-output

# Keep test projects after rendering (for inspection)
# KEEP_TEST_PROJECTS=false

# ===========================================================================
# Git Configuration (for template testing)
# ===========================================================================

# Git user name for test commits
# GIT_USER_NAME=Template Test

# Git user email for test commits
# GIT_USER_EMAIL=test@example.com

# ===========================================================================
# Optional: External Tools
# ===========================================================================

# Sentry DSN for error tracking (if monitoring template generation)
# SENTRY_DSN=https://key@sentry.io/project-id

# Codecov.io token (for CI/CD integration testing)
# CODECOV_TOKEN=your-token-here
