{
  "permissions": {
    "allow": [
      "Bash(just:*)",
      "Bash(uv:*)",
      "Bash(copier:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(python3:*)",
      "Bash(bash .claude/hooks/*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(uv publish:*)",
      "Bash(git commit --no-verify:*)",
      "Bash(git push --force:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-bash-block-no-verify.sh"
          }
        ],
        "description": "Block --no-verify flag in git commands to protect pre-commit quality gates"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-bash-git-push-reminder.sh"
          }
        ],
        "description": "Warn before git push: run just review + just test first"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-bash-commit-quality.sh"
          }
        ],
        "description": "Pre-commit: scan staged .py files for secrets/debug markers before git commit"
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-config-protection.sh"
          }
        ],
        "description": "Block weakening edits to ruff/basedpyright config in pyproject.toml"
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-protect-uv-lock.sh"
          }
        ],
        "description": "Block direct edits to uv.lock — must be regenerated via uv lock or just update"
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-write-src-test-reminder.sh"
          }
        ],
        "description": "Remind to add tests/<pkg>/test_<module>.py for top-level src/<pkg>/<module>.py"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-python.sh"
          }
        ],
        "description": "Run ruff check + basedpyright after every .py edit for immediate feedback"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-markdown.sh"
          }
        ],
        "description": "Post-edit fallback: warn if an existing .md file is edited outside docs/"
      }
    ]
  }
}
