# Documentation build and deploy workflow — builds MkDocs and deploys to GitHub Pages.
# Build runs on every push and PR (for validation); deploy runs only on non-PR events.
#
# References:
#   GitHub Pages deployment:    https://docs.github.com/en/pages/getting-started-with-github-pages/configuring-a-publishing-source-for-your-github-pages-site
#   actions/deploy-pages:       https://github.com/actions/deploy-pages
#   MkDocs:                     https://www.mkdocs.org/
#   Security hardening:         https://docs.github.com/en/actions/security-for-github-actions/security-guides/security-hardening-for-github-actions
#   Concurrency best practices: https://docs.github.com/en/actions/writing-workflows/choosing-what-your-workflow-does/using-concurrency
#   Workflow permissions:       https://docs.github.com/en/actions/security-guides/automatic-token-authentication#modifying-the-permissions-for-the-github_token
name: Docs

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]
  workflow_dispatch:

# pages:write + id-token:write are required by actions/deploy-pages for OIDC-based deployment.
permissions:
  contents: read
  pages: write
  id-token: write

# Allow only one concurrent deployment to GitHub Pages; cancel queued runs but keep in-progress.
concurrency:
  group: pages-{% raw %}${{ github.workflow }}-${{ github.ref }}{% endraw %}
  cancel-in-progress: true

jobs:
  build:
    name: Build Docs
    if: >-
      {% if include_docs -%}
      {% raw %}${{ true }}{% endraw %}
      {%- else -%}
      {% raw %}${{ false }}{% endraw %}
      {%- endif %}
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v6

      - name: Install uv
        uses: astral-sh/setup-uv@v8.0.0
        with:
          enable-cache: true

      - name: Set up Python
        run: uv python install {{ python_min_version }}

      - name: Install docs dependencies
        run: uv sync --frozen --extra docs

      - name: Build docs
        run: uv run mkdocs build --strict --site-dir site

      - name: Upload Pages artifact
        if: {% raw %}${{ github.event_name != 'pull_request' }}{% endraw %}
        uses: actions/upload-pages-artifact@v3
        with:
          path: site

  deploy:
    name: Deploy to GitHub Pages
    needs: build
    if: >-
      {% if include_docs -%}
      {% raw %}${{ github.event_name != 'pull_request' }}{% endraw %}
      {%- else -%}
      {% raw %}${{ false }}{% endraw %}
      {%- endif %}
    runs-on: ubuntu-latest
    environment:
      name: github-pages
      url: {% raw %}${{ steps.deployment.outputs.page_url }}{% endraw %}
    steps:
      - name: Deploy to GitHub Pages
        id: deployment
        uses: actions/deploy-pages@v4
