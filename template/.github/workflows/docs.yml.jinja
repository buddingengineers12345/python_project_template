name: Docs

on:
  push:
    branches: [main]
  workflow_dispatch:

jobs:
  build:
    if: >-
      {% if include_docs -%}
      {% raw %}${{ true }}{% endraw %}
      {%- else -%}
      {% raw %}${{ false }}{% endraw %}
      {%- endif %}
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Install uv
        uses: astral-sh/setup-uv@v5
        with:
          enable-cache: true

      - name: Set up Python
        run: uv python install {{ python_min_version }}

      - name: Install docs dependencies
        run: uv sync --frozen --extra docs

      - name: Build docs
        run: uv run mkdocs build --strict --site-dir site

      - name: Upload site artifact
        uses: actions/upload-artifact@v4
        with:
          name: site
          path: site

