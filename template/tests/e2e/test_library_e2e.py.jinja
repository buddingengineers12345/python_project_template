# ---------------------------------------------------------------------------
# Version bump — round-trip through pyproject.toml
# ---------------------------------------------------------------------------


def test_version_round_trip(tmp_path: Path) -> None:
    """A version can be read, bumped, written, and read back correctly."""
    import textwrap

    from {{ package_name }}.common.bump_version import (
        Version,
        _read_project_version,  # pyright: ignore[reportPrivateUsage]
        _write_project_version,  # pyright: ignore[reportPrivateUsage]
    )

    pyproject = tmp_path / "pyproject.toml"
    pyproject.write_text(
        textwrap.dedent("""\
            [project]
            name = "{{ package_name }}"
            version = "0.1.0"
        """),
        encoding="utf-8",
    )

    current = _read_project_version(pyproject)
    assert current == Version(0, 1, 0)

    new_version = current.bumped("minor")
    _write_project_version(pyproject, new_version)

    updated = _read_project_version(pyproject)
    assert updated == Version(0, 2, 0)
