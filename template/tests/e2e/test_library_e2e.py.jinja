"""End-to-end tests for :mod:`{{ package_name }}`.

Exercise the library from the public API inward, simulating consumer usage without
mocking internal components.
"""

from __future__ import annotations

import json
from pathlib import Path

import pytest

pytestmark = pytest.mark.e2e


# ---------------------------------------------------------------------------
# Package import surface
# ---------------------------------------------------------------------------


def test_package_imports_cleanly() -> None:
    """Importing the package must not raise."""
    import {{ package_name }}  # noqa: F401 — import-only test


def test_package_exposes_version() -> None:
    """:mod:`{{ package_name }}` must expose a non-empty ``__version__`` string."""
    import {{ package_name }}

    version = getattr({{ package_name }}, "__version__", "")
    assert isinstance(version, str)
    assert version


def test_all_public_symbols_importable() -> None:
    """Every symbol listed in ``__all__`` must be reachable on the package."""
    import {{ package_name }}

    all_symbols = getattr({{ package_name }}, "__all__", [])
    for symbol in all_symbols:
        assert hasattr({{ package_name }}, symbol), f"__all__ symbol {symbol!r} is not accessible"


