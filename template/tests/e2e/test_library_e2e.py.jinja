# ---------------------------------------------------------------------------
# file_manager — real filesystem round-trip
# ---------------------------------------------------------------------------


def test_load_json_real_file(tmp_path: Path) -> None:
    """load_json reads back exactly what was written using the real filesystem."""
    from {{ package_name }}.common.file_manager import load_json

    payload = {"library": "{{ package_name }}", "version": 1}
    p = tmp_path / "config.json"
    p.write_text(json.dumps(payload), encoding="utf-8")
    assert load_json(p) == payload


def test_load_markdown_real_file(tmp_path: Path) -> None:
    """load_markdown reads back exactly what was written using the real filesystem."""
    from {{ package_name }}.common.file_manager import load_markdown

    content = "# Title\n\nBody paragraph."
    p = tmp_path / "README.md"
    p.write_text(content, encoding="utf-8")
    assert load_markdown(p) == content


def test_load_json_missing_file_raises() -> None:
    """load_json raises FileNotFoundError for a non-existent path."""
    from {{ package_name }}.common.file_manager import load_json

    with pytest.raises(FileNotFoundError):
        load_json(Path("/tmp/definitely_does_not_exist_e2e_test.json"))


