def test_log_fields_empty_dict_does_not_raise() -> None:
    """An empty dict must not raise — emits a no_fields event."""
    configure_logging(context="human", level="DEBUG")
    log_fields({})


def test_log_fields_string_values_does_not_raise() -> None:
    """log_fields with string values must not raise."""
    configure_logging(context="human", level="DEBUG")
    log_fields({"name": "alice", "role": "admin"})


def test_log_fields_list_values_does_not_raise() -> None:
    """log_fields with list values must not raise."""
    configure_logging(context="human", level="DEBUG")
    log_fields({"items": ["a", "b", "c"]})


def test_log_fields_mixed_values_does_not_raise() -> None:
    """log_fields with mixed value types must not raise."""
    configure_logging(context="human", level="DEBUG")
    log_fields({"count": 3, "label": "test", "tags": ["x", "y"]})


