"""Tests for public human-mode helpers in :mod:`{{ package_name }}.common.logging_manager`."""

from __future__ import annotations

import pytest

from {{ package_name }}.common.logging_manager import (
    configure_logging,
    list_to_numbered_string,
    log_fields,
    log_message,
    log_section,
    log_section_divider,
    log_sub_section,
    wrap_text,
)

pytestmark = pytest.mark.unit


# ---------------------------------------------------------------------------
# configure_logging guard behaviour
# ---------------------------------------------------------------------------


def test_configure_logging_idempotent_same_settings() -> None:
    """Calling configure_logging twice with the same settings must not raise."""
    configure_logging(context="human", level="WARNING")
    configure_logging(context="human", level="WARNING")  # second call — idempotent


def test_configure_logging_different_settings_raises() -> None:
    """Calling configure_logging twice with different settings raises RuntimeError."""
    configure_logging(context="human", level="INFO")
    with pytest.raises(RuntimeError, match="configure_logging\\(\\) called multiple times"):
        configure_logging(context="human", level="DEBUG")


# ---------------------------------------------------------------------------
# wrap_text
# ---------------------------------------------------------------------------


def test_wrap_text_short_string_unchanged() -> None:
    """Strings shorter than the width pass through unchanged."""
    result = wrap_text("hello", width=80)
    assert result == "hello"


def test_wrap_text_long_string_wraps() -> None:
    """Strings longer than width are broken at word boundaries."""
    long = "word " * 20
    result = wrap_text(long.strip(), width=20)
    assert max(len(line) for line in result.splitlines()) <= 20


def test_wrap_text_default_width() -> None:
    """wrap_text uses LOG_LINE_WIDTH as the default column width."""
    from {{ package_name }}.common.logging_manager import LOG_LINE_WIDTH

    text = "a " * (LOG_LINE_WIDTH + 10)
    result = wrap_text(text.strip())
    assert any(len(line) <= LOG_LINE_WIDTH for line in result.splitlines())


# ---------------------------------------------------------------------------
# list_to_numbered_string
# ---------------------------------------------------------------------------


def test_list_to_numbered_string_empty_list() -> None:
    """An empty list produces an empty string."""
    assert list_to_numbered_string([]) == ""


def test_list_to_numbered_string_single_item() -> None:
    """A single-item list produces a string starting with newline + '1. item'."""
    result = list_to_numbered_string(["alpha"])
    assert result.startswith("\n")
    assert "1. alpha" in result


def test_list_to_numbered_string_multiple_items() -> None:
    """Items are numbered sequentially from 1."""
    result = list_to_numbered_string(["a", "b", "c"])
    assert "1. a" in result
    assert "2. b" in result
    assert "3. c" in result


def test_list_to_numbered_string_count() -> None:
    """The correct number of lines is produced."""
    items = list(range(5))
    result = list_to_numbered_string(items)
    numbered_lines = [ln for ln in result.splitlines() if ln.strip()]
    assert len(numbered_lines) == 5


