"""Smoke tests ensuring the **{{ package_name }}** package imports cleanly."""

import {{ package_name }}


def test_import() -> None:
    """Import the package and assert :data:`{{ package_name }}.__version__` is set."""
    assert {{ package_name }}.__version__ is not None


def test_version_format() -> None:
    """Assert the version string looks like a semver when the package is installed."""
    version = {{ package_name }}.__version__
    if version == "unknown":
        return
    parts = version.split(".")
    assert len(parts) >= 2, f"Version {version} should have at least major.minor"
