"""Centralized logging setup and human-readable log formatting for **{{ project_name }}**.

Configures the root logger, suppresses noisy third-party loggers, and provides
helpers for sections, key/value fields, and wrapped text in log output.
"""

from __future__ import annotations

import logging
import os
import textwrap
from typing import Any

LOG_LEVEL = int(os.getenv("LOG_LEVEL", str(logging.INFO)))

LOG_LINE_WIDTH: int = 75
PADDING_WIDTH: int = 30

if LOG_LEVEL == logging.DEBUG:
    logging.basicConfig(
        level=LOG_LEVEL,
        format="%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    )
else:
    logging.basicConfig(
        level=LOG_LEVEL,
        format="%(message)s",
    )

logging.getLogger("httpx").setLevel(logging.WARNING)
logging.getLogger("httpcore").setLevel(logging.WARNING)
logging.getLogger("urllib3").setLevel(logging.WARNING)


def get_logger(name: str) -> logging.Logger:
    """Return a :class:`logging.Logger` for the given dotted context name.

    Args:
        name: Logger name, usually ``__name__`` of the calling module.

    Returns:
        The :mod:`logging` hierarchy logger for ``name``.
    """
    return logging.getLogger(name)


def list_to_numbered_string(items: list[str]) -> str:
    """Format ``items`` as a newline-prefixed numbered list string.

    Args:
        items: Non-empty list of lines to number starting at 1.

    Returns:
        Empty string if ``items`` is empty; otherwise a string beginning with a
        newline, then ``"1. …"``, ``"2. …"``, and so on.
    """
    if not items:
        return ""

    numbered_items = [f"{index}. {item}" for index, item in enumerate(items, start=1)]
    return "\n" + "\n".join(numbered_items)


def wrap_text(text: str, width: int = LOG_LINE_WIDTH) -> str:
    """Wrap each paragraph of ``text`` to at most ``width`` columns.

    Existing single newlines are treated as paragraph breaks.

    Args:
        text: Input text; empty or falsey values yield an empty string.
        width: Maximum line length passed to :func:`textwrap.fill`.

    Returns:
        Wrapped text joined with newlines between paragraphs.
    """
    if not text:
        return ""

    paragraphs = str(text).split("\n")
    wrapped = [textwrap.fill(paragraph, width=width) for paragraph in paragraphs]
    return "\n".join(wrapped)


def log_section(title: str, level: int = logging.INFO) -> None:
    """Emit a prominent section header (repeated ``=`` lines around ``title``).

    Args:
        title: Heading text.
        level: Logging level (e.g., logging.DEBUG, logging.INFO).
    """
    logger = get_logger(__name__)
    separator = "=" * int(LOG_LINE_WIDTH * 1.1)
    logger.log(level, separator)
    logger.log(level, title)
    logger.log(level, separator)


def log_sub_section(title: str, level: int = logging.INFO) -> None:
    """Emit a sub-section header using ``-`` rule lines.

    Args:
        title: Sub-heading text.
        level: Logging level (e.g., logging.DEBUG, logging.INFO).
    """
    logger = get_logger(__name__)
    separator = "-" * LOG_LINE_WIDTH
    logger.log(level, separator)
    logger.log(level, title)
    logger.log(level, separator)


def log_section_divider(level: int = logging.INFO) -> None:
    """Emit a single horizontal rule line.

    Args:
        level: Logging level (e.g., logging.DEBUG, logging.INFO).
    """
    logger = get_logger(__name__)
    separator = "-" * LOG_LINE_WIDTH
    logger.log(level, separator)


def log_fields(fields: dict[str, Any], level: int = logging.INFO) -> None:
    """Log ``fields`` with keys padded for aligned ``:`` columns.

    List values are rendered via :func:`list_to_numbered_string`; long strings are
    wrapped via :func:`wrap_text`.

    Args:
        fields: Mapping to print as key/value lines.
        level: Logging level (e.g., logging.DEBUG, logging.INFO).
    """
    logger = get_logger(__name__)

    if not fields:
        logger.log(level, "No fields to display.")
        return

    for key, value in fields.items():
        formatted_value: Any = (
            list_to_numbered_string(value) if isinstance(value, list) else value
        )

        if isinstance(formatted_value, str):
            if formatted_value.startswith("\n"):
                lines = formatted_value.split("\n")
                wrapped_lines = [lines[0]] + [
                    wrap_text(line, width=LOG_LINE_WIDTH) for line in lines[1:]
                ]
                formatted_value = "\n" + "\n".join(wrapped_lines[1:])
            else:
                formatted_value = wrap_text(formatted_value, width=LOG_LINE_WIDTH)

        logger.log(level, "  %-*s : %s", PADDING_WIDTH, key, formatted_value)


def log_message(message: str, level: int = logging.INFO) -> None:
    """Log ``message`` at ``level`` after :func:`wrap_text` processing.

    Args:
        message: Free-form text.
        level: Logging level (e.g., logging.DEBUG, logging.INFO).
    """
    logger = get_logger(__name__)
    wrapped = wrap_text(message, width=LOG_LINE_WIDTH)
    logger.log(level, wrapped)
