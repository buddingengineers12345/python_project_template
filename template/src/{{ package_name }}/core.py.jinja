T = TypeVar("T")


def example_function(value: T) -> T:
    """Return ``value`` unchanged (identity placeholder).

    Use this pattern as a starting point for typed helpers: document parameters,
    return type, and edge cases your real implementation will handle.

    Args:
        value: Arbitrary input; returned as-is.

    Returns:
        The same object that was passed in.

    Examples:
        >>> example_function(42)
        42
        >>> example_function("hello")
        'hello'
    """
