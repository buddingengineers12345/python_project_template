{% if include_numpy %}
def example_array_function(arr: npt.NDArray[np.float64]) -> npt.NDArray[np.float64]:
    """Return a new array whose elements are the squares of ``arr``.

    Args:
        arr: One-dimensional or multi-dimensional array of ``float64`` values.

    Returns:
        An array of the same shape as ``arr`` with each element squared.

    Examples:
        >>> import numpy as np
        >>> example_array_function(np.array([1.0, 2.0, 3.0]))
        array([1., 4., 9.])
    """
    return arr**2
{% endif %}


{% if include_pandas_support %}
def example_dataframe_function(df: pd.DataFrame) -> pd.DataFrame:
    """Return a shallow-safe copy of ``df`` (mutations to the copy do not affect ``df``).

    Args:
        df: Any :class:`pandas.DataFrame`.

    Returns:
        A new DataFrame with the same data as ``df``.

    Examples:
        >>> import pandas as pd
        >>> df = pd.DataFrame({"a": [1, 2, 3]})
        >>> out = example_dataframe_function(df)
        >>> out.equals(df)
        True
    """
    return df.copy()
{% endif %}
