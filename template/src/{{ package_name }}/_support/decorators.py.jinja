"""Reusable function decorators (timing, exception logging, default return values).

Decorators support both synchronous and asynchronous callables by inspecting the
target with :func:`inspect.iscoroutinefunction`.
"""

from __future__ import annotations

import copy
import inspect
import logging
import time
from functools import wraps
from typing import TYPE_CHECKING, ParamSpec, TypeVar

if TYPE_CHECKING:
    from collections.abc import Callable

from {{ package_name }}._support.logging_manager import get_logger, log_message

P = ParamSpec("P")
R = TypeVar("R")
logger = get_logger(__name__)


def handle_exceptions(func: Callable[P, R]) -> Callable[P, R]:
    """Log exceptions with traceback, then re-raise.

    Works for both sync and async callables.

    Args:
        func: Callable to wrap.

    Returns:
        A wrapper that preserves the original signature and behavior except for
        added logging on failure.

    Example:
        >>> @handle_exceptions
        ... def risky() -> None:
        ...     raise ValueError("fail")
    """
    if inspect.iscoroutinefunction(func):

        @wraps(func)
        async def async_wrapper(*args: P.args, **kwargs: P.kwargs) -> R:
            try:
                return await func(*args, **kwargs)  # type: ignore[misc]
            except Exception as exc:
                logger.error("Exception in %s: %s", func.__name__, exc, exc_info=True)
                raise

        return async_wrapper  # type: ignore[return-value]

    @wraps(func)
    def sync_wrapper(*args: P.args, **kwargs: P.kwargs) -> R:
        try:
            return func(*args, **kwargs)
        except Exception as exc:
            logger.error("Exception in %s: %s", func.__name__, exc, exc_info=True)
            raise

    return sync_wrapper


def time_function(func: Callable[P, R]) -> Callable[P, R]:
    """Log wall-clock duration of each invocation using :func:`time.perf_counter`.

    Duration is logged even when the wrapped callable raises.

    Args:
        func: Sync or async callable to measure.

    Returns:
        A wrapper that logs elapsed seconds after each call completes or fails.

    Example:
        >>> @time_function
        ... def work() -> int:
        ...     return 1
    """
    if inspect.iscoroutinefunction(func):

        @wraps(func)
        async def async_wrapper(*args: P.args, **kwargs: P.kwargs) -> R:
            start_time = time.perf_counter()
            try:
                return await func(*args, **kwargs)  # type: ignore[misc]
            finally:
                elapsed = time.perf_counter() - start_time
                log_message(f"Function {func.__name__} executed in {elapsed:.4f} seconds")

        return async_wrapper  # type: ignore[return-value]

    @wraps(func)
    def sync_wrapper(*args: P.args, **kwargs: P.kwargs) -> R:
        start_time = time.perf_counter()
        try:
            return func(*args, **kwargs)
        finally:
            elapsed = time.perf_counter() - start_time
            log_message(f"Function {func.__name__} executed in {elapsed:.4f} seconds")

    return sync_wrapper


def handle_exceptions_valued(
    default: object = None,
    level: int = logging.ERROR,
) -> Callable[[Callable[P, R]], Callable[P, R | None]]:
    """Return a decorator that logs exceptions and returns ``default`` instead of raising.

    The ``default`` value is deep-copied on each failure so mutable defaults (for
    example ``[]`` or ``{}``) are not shared across calls.

    Args:
        default: Value to return when the wrapped callable raises.
        level: Log level passed to :meth:`logging.Logger.log` for the failure record.

    Returns:
        A decorator that produces a wrapped callable with the same call signature
        but a return type that includes ``None`` when exceptions are swallowed.

    Example:
        >>> @handle_exceptions_valued(False)
        ... def may_fail() -> bool:
        ...     return True
    """

    def decorator(func: Callable[P, R]) -> Callable[P, R | None]:
        if inspect.iscoroutinefunction(func):

            @wraps(func)
            async def async_wrapper(*args: P.args, **kwargs: P.kwargs) -> R | None:
                try:
                    return await func(*args, **kwargs)  # type: ignore[misc]
                except Exception as exc:
                    logger.log(
                        level,
                        "Exception in %s: %s",
                        func.__name__,
                        exc,
                        exc_info=True,
                    )
                    return copy.deepcopy(default)  # type: ignore[return-value]

            return async_wrapper  # type: ignore[return-value]

        @wraps(func)
        def sync_wrapper(*args: P.args, **kwargs: P.kwargs) -> R | None:
            try:
                return func(*args, **kwargs)
            except Exception as exc:
                logger.log(
                    level,
                    "Exception in %s: %s",
                    func.__name__,
                    exc,
                    exc_info=True,
                )
                return copy.deepcopy(default)  # type: ignore[return-value]

        return sync_wrapper  # type: ignore[return-value]

    return decorator
