"""Environment and process utilities (standard library only in hot paths).

Helpers here probe the runtime (e.g. GPU presence) and load project configuration.
They are intentionally small and dependency-light where possible so they are safe to
call during startup and in CI.
"""

from __future__ import annotations

import shutil
import subprocess
import warnings
from pathlib import Path

from dotenv import load_dotenv

from {{ package_name }}._support.decorators import handle_exceptions_valued
from {{ package_name }}._support.logging_manager import log_message

warnings.filterwarnings("ignore")


@handle_exceptions_valued(False)
def has_nvidia_gpu() -> bool:
    """Return whether ``nvidia-smi`` runs successfully (NVIDIA driver stack present).

    A successful invocation of ``nvidia-smi`` is treated as evidence that an NVIDIA
    GPU and drivers are available. Any subprocess or command error results in
    ``False``.

    Returns:
        ``True`` if ``nvidia-smi`` exists on ``PATH`` and exits successfully;
        ``False`` otherwise.

    Note:
        This check is NVIDIA-specific. Systems with only AMD, Intel, or Apple GPUs
        typically return ``False`` even when a GPU is present.
    """
    cmd = shutil.which("nvidia-smi")
    if cmd is None:
        return False
    subprocess.check_output([cmd])
    return True


def load_project_env(dotenv_filename: str = ".env") -> bool:
    """Load key/value pairs from a ``.env`` file at the inferred project root.

    The project root is found by walking parents of the resolved ``python`` on
    ``PATH`` until a directory containing a ``.venv`` folder is found, then
    ``dotenv_filename`` is loaded from that directory if it exists.

    Args:
        dotenv_filename: Name of the env file relative to the project root.

    Returns:
        ``True`` if the file existed and was loaded; ``False`` if the file is
        missing or the project root could not be determined (after logging).
    """
    try:
        which_python = shutil.which("python")
        if which_python is None:
            raise RuntimeError("python executable not found on PATH")
        python_path = Path(which_python).resolve()
        project_root: Path | None = None
        for parent in python_path.parents:
            if (parent / ".venv").is_dir():
                project_root = parent
                break
        if project_root is None:
            raise RuntimeError(".venv not found in python path hierarchy")
    except Exception as exc:
        log_message(f"Could not determine project root from Python executable: {exc}")
        return False

    log_message(f"Python interpreter detected at: {which_python}")
    log_message(f"Project root detected at: {project_root}")

    dotenv_path = project_root / dotenv_filename
    if not dotenv_path.is_file():
        return False

    load_dotenv(dotenv_path=dotenv_path, override=False)
    return True


def get_simple_attributes(obj: object) -> dict[str, str | int | float]:
    """Collect public attributes of ``obj`` whose values are ``str``, ``int``, or ``float``.

    Attributes whose names start with ``_``, or whose values are callables,
    containers, or other complex types, are omitted.

    Args:
        obj: Any object supporting :func:`vars` (typically a class instance).

    Returns:
        Mapping from attribute name to value for simple scalar fields only.
    """
    allowed_types = (str, int, float)

    return {
        key: value
        for key, value in vars(obj).items()
        if not key.startswith("_") and isinstance(value, allowed_types)
    }
